[submodule "submodules/zsh-autosuggestions"]
	path = submodules/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions.git
[submodule "submodules/fast-syntax-highlighting"]
	path = submodules/fast-syntax-highlighting
	url = https://github.com/zdharma-continuum/fast-syntax-highlighting
[submodule "submodules/zsh-completions"]
	path = submodules/zsh-completions
	url = https://github.com/zsh-users/zsh-completions.git
[submodule "submodules/zsh-no-ps2"]
	path = submodules/zsh-no-ps2
	url = https://github.com/romkatv/zsh-no-ps2.git
[submodule "submodules/zsh-bd"]
	path = submodules/zsh-bd
	url = https://github.com/Tarrasch/zsh-bd.git
[submodule ".homedir/.config/yazi/flavors"]
	path = .homedir/.config/yazi/flavors
	url = https://github.com/yazi-rs/flavors.git
[submodule "submodules/themes/bat"]
	path = submodules/themes/bat
	url = https://github.com/catppuccin/bat.git
[submodule "submodules/themes/delta"]
	path = submodules/themes/delta
	url = https://github.com/catppuccin/delta.git
[submodule "submodules/themes/zsh-fsh"]
	path = submodules/themes/zsh-fsh
	url = https://github.com/catppuccin/zsh-fsh.git
[submodule "submodules/themes/lazygit"]
	path = submodules/themes/lazygit
